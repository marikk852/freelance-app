# ==========================================
# SafeDeal — Environment Variables Example
# Скопируй в .env и заполни все значения
# НИКОГДА не коммить .env в git!
# ==========================================

# --- Telegram ---
BOT_TOKEN=                          # @BotFather → /newbot
WEBAPP_URL=                         # https://your-domain.com (или ngrok для dev)

# Mini App (Vite): если API на другом домене — укажи полный URL API, иначе оставь пустым (тот же origin /api)
# VITE_API_URL=

# --- База данных ---
DATABASE_URL=postgresql://user:password@localhost:5432/safedeal

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- TON Блокчейн ---
TON_API_KEY=                        # https://toncenter.com → API key
TON_ENDPOINT=https://toncenter.com/api/v2/
TON_TESTNET_ENDPOINT=https://testnet.toncenter.com/api/v2/

# --- Арбитраж (кошелёк платформы) ---
ARBITRATOR_WALLET_SEED=             # 24 слова мнемоники — СТРОГО СЕКРЕТНО
ARBITRATOR_ADDRESS=                 # UQ... адрес кошелька арбитра

# --- Финансы ---
PLATFORM_FEE_PERCENT=2              # Комиссия платформы (2%)
MAX_DEAL_AMOUNT_USD=500             # Лимит сделки на старте

# --- Шифрование файлов ---
ENCRYPTION_KEY=                     # 64 hex символа (256 бит) для AES-256-CBC
# Генерация: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# --- Сервер ---
PORT=3000
NODE_ENV=development                # development | production

# --- Хранилище файлов ---
STORAGE_PATH=./storage              # Путь к папке хранилища
MAX_FILE_SIZE_MB=100                # Максимальный размер файла в MB

# --- JWT (для Web App) ---
JWT_SECRET=                         # Случайная строка для подписи токенов
JWT_EXPIRES_IN=7d

# --- Логирование ---
LOG_LEVEL=info                      # error | warn | info | debug
