{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "build",
    "rootDir": ".",
    "resolveJsonModule": true
  },
  "include": ["wrappers/**/*", "tests/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "build"]
}
